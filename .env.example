# Scopus / Elsevier API Key
# Obtenha em: https://dev.elsevier.com/
SCOPUS_API_KEY=	10625492caedfa70a74b73ce3a551ab1

# IEEE Xplore API Key
# Obtenha em: https://developer.ieee.org/
IEEE_API_KEY=your_ieee_api_key_here

# Springer Nature API Key
# Obtenha em: https://dev.springernature.com/
# Para Open Access API: SPRINGER_API_MODE=openaccess
# Para Metadata API:    SPRINGER_API_MODE=metadata
SPRINGER_API_MODE=openaccess
SPRINGER_API_KEY=your_springer_api_key_here

# Web of Science Starter API Key (Clarivate) — gratuito
# Cadastro em: https://developer.clarivate.com/
WOS_API_KEY=your_wos_api_key_here

# Configurações opcionais
# Delay em segundos entre requisições (evitar rate limiting)
REQUEST_DELAY=1.0

# Número máximo de resultados por query (0 = sem limite)
MAX_RESULTS_PER_QUERY=0

# Diretório de saída (padrão: results/)
RESULTS_DIR=results

# Email para o User-Agent do OpenAlex (dá acesso à polite pool — maior rate limit)
# Substitua pelo seu email institucional ou pessoal
OPENALEX_EMAIL=seu_email@exemplo.com

# Chave Anthropic (para triagem T/A via Batches API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Chave Semantic Scholar (opcional — sem chave: ~1 req/s; com chave gratuita: ~10 req/s)
# Cadastro gratuito em: https://www.semanticscholar.org/product/api
S2_API_KEY=your_s2_api_key_here

# Chave CORE API (opcional — habilita fallback adicional de abstract/full text)
# Cadastro em: https://core.ac.uk/services/api
CORE_API_KEY=your_core_api_key_here
